# Discord Bot Token (Required)
DISCORD_TOKEN=your_discord_bot_token

# Discord Application ID (Required)
APPLICATION_ID=123456789012345678

# Optional: logging level (default: INFO)
LOG_LEVEL=INFO

# Optional: confirmation TTL in seconds (default: 600 seconds = 10 minutes)
CONFIRM_TTL_SECONDS=600

# Optional: direct URL template for export schema hint comment
# Use {version} placeholder when you want version-aware hints.
# Exported YAML will include:
#   # yaml-language-server: $schema=<SCHEMA_HINT_URL_TEMPLATE with {version} replaced>
# example:
#   https://varubogu.github.io/guild_schema_manager/schema/v1/schema.json
SCHEMA_HINT_URL_TEMPLATE=https://varubogu.github.io/guild_schema_manager/schema/v1/schema.json
