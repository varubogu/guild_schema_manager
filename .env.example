# Discord Bot Token (Required)
DISCORD_TOKEN=your_discord_bot_token

# Discord Application ID (Required)
APPLICATION_ID=123456789012345678

# Optional: logging level (default: INFO)
LOG_LEVEL=INFO

# Optional: confirmation TTL in seconds (default: 600 seconds = 10 minutes)
CONFIRM_TTL_SECONDS=600

# Optional: GitHub repository owner/name for export schema hint URL
# Exported YAML will include:
#   # yaml-language-server: $schema=https://<owner>.github.io/<repo>/schema/v<version>/schema.json
SCHEMA_REPO_OWNER=your-github-org-or-user
SCHEMA_REPO_NAME=guild_schema_manager
